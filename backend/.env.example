# ─── Server ───
PORT=4000
NODE_ENV=development

# ─── Database (PostgreSQL) ───
DB_HOST=localhost
DB_PORT=5444
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=news_engine

# ─── node-pg-migrate requires DATABASE_URL ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5444/news_engine

# ─── JWT ───
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=3d

# ─── CORS ───
CORS_ORIGIN=http://localhost:3033
