# ═══════════════════════════════════════════════════════════════
#  NEWS-ENGINE  —  Environment Configuration Template
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Database (shared with backend) ──────────────────────────
DB_HOST=localhost
DB_PORT=5444
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=strapi

# ─── CMS / Strapi ───────────────────────────────────────────
CMS_BASE_URL=http://localhost:1337
CMS_ADMIN_USER_EMAIL=your-email@example.com
PASSWORD_SECRET_KEY=your-aes-password-secret-key

# ─── AI Service Selection ───────────────────────────────────
#  content: openai | openrouter | gemini
#  image:   openrouter | imagen | gemini-flash-image | skip
CONTENT_GENERATE_SERVICE=gemini
IMAGE_GENERATE_SERVICE=gemini-flash-image

# ─── Google Gemini ──────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
GOOGLE_GEMINI_API_KEYS=key1,key2,key3
GOOGLE_GEMINI_MODEL=gemini-3.1-flash-image-preview
GOOGLE_GEMINI_CONTENT_MODEL=gemini-2.5-flash
GOOGLE_IMAGEN_MODEL=imagen-4.0-generate-001

# ─── OpenRouter (used when *_SERVICE=openrouter) ────────────
OPEN_ROUTER_API_KEY=your-openrouter-api-key
OPEN_ROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image
OPEN_ROUTER_CONTENT_MODEL=google/gemini-2.0-flash-001

# ─── OpenAI (used when CONTENT_GENERATE_SERVICE=openai) ─────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.1

# ─── Twitter / X Scraping ───────────────────────────────────
TWITTER_USERNAME=your-twitter-username
TWITTER_PASSWORD=your-twitter-password
TWITTER_EMAIL=your-twitter-email
X_API_BEARER_TOKEN=your-x-api-bearer-token

# ─── Email Alerts (SendGrid) ────────────────────────────────
SENDER_EMAIL=recipient@example.com
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=sender@example.com

# ─── Application Settings ───────────────────────────────────
APP_TIMEZONE=Asia/Kolkata
MAX_POSTS_PER_RUN=0
